# Mogo(모의) 로컬 개발 환경 (.env.development)
# next dev 시 자동 로드됨 (.env.local보다 낮은 우선순위)

# Mogo Backend API (포트 4009 고정)
NEXT_PUBLIC_API_URL=http://localhost:4009

# Mogo Frontend URL (포트 3009 고정)
NEXT_PUBLIC_FRONT_URL=http://localhost:3009

# Hub (T스쿨) 연동 - 로컬 개발용
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_HUB_API_URL=http://localhost:4000
